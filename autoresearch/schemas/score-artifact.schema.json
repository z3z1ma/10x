{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/10x/autoresearch/score-artifact.schema.json",
  "title": "10x Autoresearch Score Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experiment_id",
    "scenario_id",
    "variant_id",
    "rep",
    "model",
    "harness",
    "instruction_digest",
    "fixture_digest",
    "scores",
    "cost",
    "limits",
    "scorer"
  ],
  "properties": {
    "experiment_id": {
      "type": "string",
      "pattern": "^EXP-[0-9]{8}-[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "scenario_id": {
      "type": "string",
      "pattern": "^SCN-[0-9]{3}(?:-[a-z0-9]+)*$"
    },
    "variant_id": {
      "type": "string",
      "minLength": 1
    },
    "rep": {
      "type": "integer",
      "minimum": 0
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "harness": {
      "type": "string",
      "minLength": 1
    },
    "instruction_digest": {
      "type": "string",
      "minLength": 1
    },
    "fixture_digest": {
      "type": "string",
      "minLength": 1
    },
    "scores": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/score"
      },
      "propertyNames": {
        "pattern": "^S00[1-9](?:_[a-z0-9]+)*$"
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_seconds",
        "tool_calls"
      ],
      "properties": {
        "wall_seconds": {
          "type": "number",
          "minimum": 0
        },
        "input_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "output_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "tool_calls": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_usd": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "human_inspection_seconds": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "description": "Tracked separately at first and not automatically folded into S009."
        },
        "resident_context_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "scorer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "trust_level",
        "inputs",
        "outputs",
        "known_false_positives",
        "known_false_negatives",
        "confidence",
        "manual_inspection_required",
        "manual_inspection_requirement",
        "limits"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "trust_level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "known_false_positives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "known_false_negatives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "manual_inspection_required": {
          "type": "boolean"
        },
        "manual_inspection_requirement": {
          "type": "string",
          "minLength": 1
        },
        "limits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "manual_inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "not-required",
            "required-not-done",
            "sampled",
            "complete"
          ]
        },
        "artifact_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "limits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "floor_triggers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/floor_trigger"
      },
      "default": []
    },
    "limits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "raw_artifact_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      },
      "default": []
    }
  },
  "$defs": {
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1
    },
    "floor_trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score_id",
        "condition"
      ],
      "properties": {
        "score_id": {
          "type": "string",
          "pattern": "^S00[1-9]$"
        },
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "cap": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "effect": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_ref"
          },
          "default": []
        }
      }
    },
    "score": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "confidence",
        "floor_triggered",
        "rationale",
        "evidence_refs",
        "limits"
      ],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "floor_triggered": {
          "type": "boolean"
        },
        "floor_triggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/floor_trigger"
          },
          "default": []
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "unsupported_assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "limits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
