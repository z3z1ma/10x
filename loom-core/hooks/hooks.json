{
  "description": "Emit using-Loom skill and ordered references as Claude SessionStart hook context from the loom-core package root.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "root=\"${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT:-}}\"; base=\"$root/skills/using-loom\"; printf '<mandatory-instructions>\\n' && cat \"$base/SKILL.md\" \"$base\"/references/*.md && printf '\\n</mandatory-instructions>\\n'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
