{
  "description": "Synchronize Loom always-on rules and guard bootstrap sessions.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/claude-sync-rules.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/claude-loom-restart-guard.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
