        "source": "git-subdir",
        "url": "https://github.com/z3z1ma/agent-loom.git",
        "path": "./loom-playbooks",
        "ref": "main"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity"
    }
  ]
