{
  "name": "@z3z1ma/open-loom-playbooks",
  "version": "0.3.0",
  "description": "Playbook package for optional explicit Loom workflow macros in OpenCode and Pi; requires @z3z1ma/open-loom-core.",
  "type": "module",
  "main": "./loom-playbooks.mjs",
  "exports": {
    ".": "./loom-playbooks.mjs",
    "./loom-playbooks": "./loom-playbooks.mjs"
  },
  "engines": {
    "opencode": ">=1.14.22 <2"
  },
  "peerDependencies": {
    "@z3z1ma/open-loom-core": "^0.3.0"
  },
  "pi": {
    "extensions": ["./pi/loom-playbooks.js"]
  },
  "files": [
    "loom-playbooks.mjs",
    "pi/",
    "playbooks/"
  ],
  "keywords": [
    "opencode",
    "pi-package",
    "loom",
    "playbooks",
    "agent-skills",
    "markdown"
  ],
  "author": "z3z1ma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/z3z1ma/agent-loom.git",
    "directory": "loom-playbooks"
  },
  "bugs": {
    "url": "https://github.com/z3z1ma/agent-loom/issues"
  },
  "homepage": "https://github.com/z3z1ma/agent-loom#readme",
  "scripts": {
    "smoke": "node loom-playbooks.mjs --smoke",
    "pack:check": "npm run smoke && npm pack --dry-run"
  }
}
